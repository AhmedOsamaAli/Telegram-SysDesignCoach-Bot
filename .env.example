# Local secrets for running the bot on your own machine.
# Copy this file to ".env" and fill in your own values. NEVER commit the real .env.

# From @BotFather in Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Your personal chat id (get it from @userinfobot in Telegram)
TELEGRAM_CHAT_ID=123456789

# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key

# Optional overrides
# GEMINI_MODEL=gemini-2.5-flash
# FORCE_SEND=1
